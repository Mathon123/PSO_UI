# 环境变量配置示例
# ============================
# 复制此文件为 .env 并根据需要修改

# ================================================================
# 应用程序配置
# ================================================================

# 应用程序名称
APP_NAME=PSO_UI

# 应用程序版本
APP_VERSION=1.0.0

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/pso_ui.log

# ================================================================
# 数据配置
# ================================================================

# 数据目录
DATA_DIR=data

# 输出目录
OUTPUT_DIR=output

# 图表导出格式 (png/pdf/svg)
CHART_FORMAT=png

# 图表DPI
CHART_DPI=300

# ================================================================
# PSO优化配置
# ================================================================

# 默认粒子数
DEFAULT_POPULATION=30

# 默认迭代次数
DEFAULT_MAX_ITER=100

# 随机种子 (留空则使用时间随机)
RANDOM_SEED=

# ================================================================
# UI配置
# ================================================================

# 主题 (light/dark)
UI_THEME=light

# 语言 (zh_CN/en_US)
UI_LANGUAGE=zh_CN

# 窗口大小
WINDOW_WIDTH=1280
WINDOW_HEIGHT=800
